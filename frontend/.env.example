# Copy to .env.local for local overrides (never commit .env.local).
# In production, set these in Netlify UI → Site → Environment variables.

# Full URL of the deployed Flask backend, no trailing slash.
# Leave empty to use the Vite dev proxy (/api → localhost:5000).
# Production example: https://guess-the-song-api.fly.dev
VITE_API_URL=
